<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProgramBox.Views.FolderEditWindow"
        Title="编辑文件夹快捷方式"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="编辑快捷方式" Classes="Title"/>

        <Border Classes="Card">
            <StackPanel Spacing="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="显示名称（别名）" Classes="Body"/>
                    <TextBox x:Name="AliasTextBox"
                             Watermark="例如：工作目录、文档、某项目"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="文件夹路径" Classes="Body"/>
                    <TextBox x:Name="PathTextBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="图标" Classes="Body"/>
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Width="64" Height="64"
                                CornerRadius="8"
                                Background="#EEEEEE"
                                Margin="0,0,12,0">
                            <Image x:Name="IconPreview"
                                   Width="48"
                                   Height="48"
                                   Stretch="Uniform"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                            <Button Content="使用系统文件夹图标"
                                    Click="ResetIconButton_Click"
                                    HorizontalAlignment="Left"/>
                            <Button Content="选择自定义图片..."
                                    Click="PickIconButton_Click"
                                    HorizontalAlignment="Left"/>
                            <TextBlock Text="支持 .png / .jpg / .ico，仅影响显示，不修改文件夹本身"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="取消" Click="CancelButton_Click" MinWidth="88"/>
            <Button Content="保存" Click="SaveButton_Click" MinWidth="88"/>
        </StackPanel>
    </StackPanel>
</Window>
