<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:ProgramBox.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ProgramBox.Views.DevelopmentToolsView"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="开发环境管理" Classes="Title"/>
                    <TextBlock Text="管理和配置各种编程语言的开发环境" Classes="Body"/>
                </StackPanel>

                <Button Grid.Column="1" 
                      Content="添加环境"
                      Click="AddEnvironmentButton_Click"
                      VerticalAlignment="Top"/>
            </Grid>

            <!-- Environment Cards -->
            <ItemsControl x:Name="EnvironmentItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:InsAtom">
                        <Border Classes="EnvironmentCard" 
                              Width="280" 
                              Cursor="Hand"
                              PointerPressed="EnvironmentCard_Click"
                              Tag="{Binding Key}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" 
                                                 FontSize="16" 
                                                 FontWeight="SemiBold" 
                                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Tag}" 
                                                 FontSize="12" 
                                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Content="配置"
                                              Click="ConfigureEnvironment_Click"
                                              Tag="{Binding Key}"
                                              Padding="8,4"
                                              FontSize="12"/>
                                        <Button Content="更多"
                                              ToolTip.Tip="更多操作"
                                              Click="MoreActions_Click"
                                              Tag="{Binding Key}"
                                              Padding="8,4"
                                              FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Description -->
                                <TextBlock Grid.Row="1" 
                                         Text="{Binding Description}" 
                                         Classes="Body" 
                                         Margin="0,0,0,12"
                                         MaxHeight="40"
                                         TextTrimming="CharacterEllipsis"/>

                                <!-- Status and Actions -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                        <Ellipse Width="8" Height="8" Fill="#4CAF50"/>
                                        <TextBlock Text="已安装" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                          Content="打开终端"
                                          Height="32"
                                          Padding="12,4"
                                          FontSize="12"
                                          Click="OpenTerminal_Click"
                                          Tag="{Binding Key}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State -->
            <Border x:Name="EmptyState" 
                  Classes="Card" 
                  IsVisible="False"
                  HorizontalAlignment="Center"
                  Padding="48">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="暂无开发环境" 
                             Classes="Subtitle" 
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextAlignment="Center"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="点击 添加环境 开始配置您的开发环境"
                             Classes="Body"
                             TextAlignment="Center"
                             Margin="0,0,0,16"/>
                    <Button Content="添加环境"
                          Click="AddEnvironmentButton_Click"
                          HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
