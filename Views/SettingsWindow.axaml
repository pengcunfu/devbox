<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="480"
        x:Class="ProgramBox.Views.SettingsWindow"
        Title="设置"
        Width="720" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="24">
            <TextBlock Text="设置" Classes="Title"/>
            
            <!-- General Settings -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <TextBlock Text="常规设置" Classes="Subtitle"/>
                    
                    <CheckBox x:Name="TrayIconCheckBox"
                              Content="启用托盘（关闭窗口时隐藏到托盘，不退出程序）"/>
                    <CheckBox x:Name="SelfStartingCheckBox" Content="开机自启动"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="界面语言" Classes="Body"/>
                        <ComboBox x:Name="LanguageComboBox" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="简体中文" Tag="zh-CN"/>
                            <ComboBoxItem Content="English" Tag="en-US"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Appearance Settings -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <TextBlock Text="外观设置" Classes="Subtitle"/>
                    
                    <CheckBox x:Name="DarkModeCheckBox" Content="深色模式"/>
                </StackPanel>
            </Border>
            
            <!-- Environment Path Settings -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <TextBlock Text="环境路径" Classes="Subtitle"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="基础路径" Classes="Body"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BaseEnvPathTextBox" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="浏览..." Click="BrowsePathButton_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right">
                <Button Content="保存" Click="SaveButton_Click"/>
                <Button Content="取消" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
