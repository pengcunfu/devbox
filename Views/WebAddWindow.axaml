<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProgramBox.Views.WebAddWindow"
        Title="添加网站"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="添加快捷网站" Classes="Title"/>

        <Border Classes="Card">
            <StackPanel Spacing="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="网址" Classes="Body"/>
                    <TextBox x:Name="UrlTextBox"
                             Watermark="https://example.com"/>
                </StackPanel>

                <Button x:Name="FetchButton"
                        Content="获取网站标题与图标"
                        Click="FetchButton_Click"
                        HorizontalAlignment="Left"/>

                <StackPanel x:Name="PreviewPanel" IsVisible="False" Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="显示标题" Classes="Body"/>
                        <TextBox x:Name="TitleTextBox" Watermark="网站在列表中显示的名称"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="网址" Classes="Body"/>
                        <TextBox x:Name="UrlPreview" IsReadOnly="True" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="图标" Classes="Body"/>
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Width="48" Height="48" CornerRadius="6" Background="#EEEEEE" Margin="0,0,12,0">
                                <Image x:Name="IconPreview" Width="32" Height="32" Stretch="Uniform"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                <Button Content="选择自定义图片..."
                                        Click="PickIconButton_Click"
                                        HorizontalAlignment="Left"/>
                                <TextBlock Text="可先获取网站图标，再自行替换"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="StatusText"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="取消" Click="CancelButton_Click" MinWidth="88"/>
            <Button x:Name="AddButton" Content="添加" Click="AddButton_Click" MinWidth="88" IsEnabled="False"/>
        </StackPanel>
    </StackPanel>
</Window>
